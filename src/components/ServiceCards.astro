---
interface Props {
  number: string;
  category: string;
  title: string;
  description: string;
}

const { number, category, title, description } = Astro.props;
---

<div class="relative p-8 md:p-10 rounded-xl border border-white/10 bg-[#161616]/80 backdrop-blur-md h-full flex flex-col group overflow-hidden transition-all duration-300 ease-in-out hover:border-white/30 hover:scale-[1.03] transform-gpu cursor-default select-none shadow-lg shadow-black/50">
  
  <span class="text-6xl font-light text-white/[0.05] block mb-4 transition-colors group-hover:text-white/[0.1]">
    {number}
  </span>

  <div class="relative z-10 flex flex-col h-full">
    <span class="text-[10px] tracking-[0.3em] text-gray-500 uppercase font-bold mb-2 block">
      {category}
    </span>
    
    <h3 class="text-2xl md:text-3xl font-bold mb-4 text-white leading-tight">
      {title}
    </h3>

    <p class="text-gray-400 text-sm md:text-base leading-relaxed max-w-sm">
      {description}
    </p>
  </div>

  <div class="absolute inset-0 bg-gradient-to-br from-white/[0.05] to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none"></div>
</div>