---
import { Image } from 'astro:assets';
import backgroundImage from '../assets/fond.jpeg';

const stats = [
  { label: 'MÓDULOS CREADOS', value: '+12', color: 'text-cyan-400' },
  { label: 'EFICACIA', value: '100%', color: 'text-purple-400' },
  { label: 'EMPRESAS', value: '+2', color: 'text-orange-400' },
  { label: 'INDUSTRIAS', value: '1', color: 'text-emerald-400' },
];
---

<section id="inicio" class="relative min-h-screen flex flex-col pt-32 pb-12 overflow-hidden">
  
  <div class="absolute inset-0 -z-10">
    <Image src={backgroundImage} alt="Fondo" class="w-full h-full object-cover opacity-20" />
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-black/40 to-black"></div>
  </div>

  <div class="container mx-auto px-6 flex flex-col flex-grow justify-between">
    
    <div class="flex-grow flex items-center">
      <div class="grid md:grid-cols-2 gap-12 items-center w-full">
        
        <div class="flex flex-col items-start z-10">
          <div class="flex items-center gap-2 px-3 py-1 rounded-full border border-teal-500/30 bg-teal-950/50 text-teal-300 text-xs font-medium mb-6 backdrop-blur-sm">
            <span class="w-2 h-2 rounded-full bg-teal-400 animate-pulse"></span>
            MÓDULOS VR PROFESIONALES
          </div>
          <h1 class="text-5xl md:text-7xl font-bold leading-tight mb-6">
            Desarrollamos <br />
            <span class="text-5xl md:text-7xl font-bold leading-tight mb-6">módulos VR</span> <br />
            a medida
          </h1>
          <p class="text-gray-400 text-lg mb-8 max-w-lg leading-relaxed">
            Especializados en la creación de módulos de realidad virtual personalizados para capacitación empresarial, simulaciones industriales y formación profesional de alto impacto.
          </p>
          <div class="flex flex-wrap gap-4">
            <button class="h-15 px-8 py-3 bg-white  text-black font-bold rounded-lg hover:bg-gray-200 transition-all flex items-center gap-2">
              VER MÓDULOS
            </button>
              <a href="#contactanos" class="h-15 px-8 py-3 border border-white/20 rounded-lg font-medium hover:bg-white/10 transition-all backdrop-blur-sm flex items-center gap-2 inline-flex">
                <span class="text-sm">▷</span> Contactanos
              </a>
          </div>
        </div>

        <div class="relative flex justify-center items-center min-h-[550px] z-10">
      
      <div class="absolute w-[580px] h-[580px] rounded-full border border-white/[0.04]"></div>
      <div class="absolute w-[460px] h-[460px] rounded-full border border-white/[0.07]"></div>
      
      <div class="absolute w-80 h-80 bg-purple-600/15 rounded-full blur-[100px] animate-pulse"></div>

      <div class="relative w-72 h-72 rounded-full p-[1px] bg-gradient-to-b from-white/20 to-transparent shadow-2xl shadow-purple-500/10 transition-transform duration-500 hover:scale-105">
        <div class="w-full h-full rounded-full bg-[#050505] overflow-hidden flex items-center justify-center relative">
          
          <div class="absolute inset-0 bg-gradient-to-tr from-purple-900/40 via-transparent to-cyan-900/40"></div>
          
          <svg xmlns="http://www.w3.org/2000/svg" class="w-24 h-24 text-white/90 relative z-10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.8" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"></circle>
            <line x1="2" y1="12" x2="22" y2="12"></line>
            <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
          </svg>
          
          <div class="absolute -inset-2 bg-gradient-to-t from-white/10 to-transparent blur-xl"></div>
        </div>
      </div>
    </div>
      </div>
      
    </div>

    <div class="w-full mt-24 mb-8 relative z-20">
      <div class="bg-[#0f0f11]/60 backdrop-blur-xl border border-white/5 rounded-lg py-10 px-6 shadow-2xl cursor-default select-none">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-y-8 md:gap-y-0">
          {stats.map((stat) => (
            <div class="flex flex-col items-center justify-center text-center">
              <span class={`text-4xl font-medium tracking-tight mb-2 ${stat.color}`}>
                {stat.value}
              </span>
              <span class="text-[10px] tracking-[0.2em] text-gray-500 font-bold uppercase">
                {stat.label}
              </span>
            </div>
          ))}
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  .bg-radial-gradient {
    background-image: radial-gradient(circle at center, var(--tw-content) 0%, transparent 70%);
  }
</style>