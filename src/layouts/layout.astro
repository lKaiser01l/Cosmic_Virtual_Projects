---
import '../styles/global.css';

---
<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<title>Desarrollo de Realidad Virtual | Soluciones VR para Empresas</title>
	</head>
	<body class="bg-black text-white antialiased min-h-screen relative">
		
		<div class="fixed inset-0 pointer-events-none -z-10 overflow-hidden">
			<div class="absolute top-[20%] -left-[10%] w-[70vw] h-[70vw] max-w-[800px] bg-blue-600/10 rounded-full blur-[120px] opacity-60"></div>
			
			<div class="absolute bottom-[10%] -right-[10%] w-[70vw] h-[70vw] max-w-[900px] bg-purple-600/10 rounded-full blur-[140px] opacity-50"></div>
		</div>

		<slot />

	</body>
	<style is:global>
	
	.container {
		
		width: 80% !important; 
		
		
		max-width: 1200px !important; 
		
		
		min-width: 320px !important;
		
		margin-left: auto !important;
		margin-right: auto !important;
	}

	
	section {
		width: 100%;
		display: flex;
		justify-content: center;
	}
	</style>
</html>
