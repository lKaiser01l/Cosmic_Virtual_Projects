---
const currentYear = new Date().getFullYear();
---

<footer class="relative mt-24 pb-12 text-gray-500 text-sm overflow-hidden bg-black border-t border-white/5">
  
  <div class="container mx-auto px-6 max-w-6xl pt-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-16 items-start mb-20">
      
      <div class="space-y-6">
        <div class="flex items-center gap-3">
          <svg class="w-6 h-6 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"></path>
            <polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline>
            <line x1="12" y1="22.08" x2="12" y2="12"></line>
          </svg>
          <span class="text-lg font-bold text-white tracking-tighter uppercase">Yaan Soluciones</span>
        </div>
        
        <p class="text-gray-600 text-[13px] leading-relaxed max-w-[300px]">
          Estudio especializado en desarrollo de experiencias VR premium para empresas innovadoras.
        </p>
        
        <div class="flex gap-3 pt-3">
          <a href="#" class="w-9 h-9 flex items-center justify-center rounded-lg border border-white/10 hover:border-white/30 hover:bg-white/5 transition-all text-gray-500 hover:text-white">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
          </a>

          
        </div>
      </div>

      <div class="md:justify-self-center">
        <h4 class="text-[11px] font-bold text-gray-600 uppercase tracking-[0.3em] mb-7">Servicios</h4>
        <ul class="space-y-4 text-[13.5px]">
          <li><a href="#" class="text-gray-400 hover:text-white transition-colors">Desarrollo VR</a></li>
          <li><a href="#" class="text-gray-400 hover:text-white transition-colors">Simulaciones</a></li>
          <li><a href="#" class="text-gray-400 hover:text-white transition-colors">Formación</a></li>
          <li><a href="#" class="text-gray-400 hover:text-white transition-colors">Consultoría</a></li>
        </ul>
      </div>

      <div class="md:justify-self-end">
        <h4 class="text-[11px] font-bold text-gray-600 uppercase tracking-[0.3em] mb-7">Contacto</h4>
        <ul class="space-y-4 text-[13.5px] text-gray-400">
          <li><a href="mailto:giancarlo@GiancarlosSoluciones.com" class="hover:text-white transition-colors">giancarlo@YaanSoluciones.com</a></li>
          <li>+51 970 936 434</li>
          <li>Lima, Perú</li>
        </ul>
      </div>

    </div>

    <div class="pt-8 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-4 text-[12px] text-gray-600">
      <p>
        © {currentYear} Giancarlos Soluciones. Todos los derechos reservados.
      </p>
      
      <div class="flex gap-6">
        <a href="#" class="hover:text-white transition-colors">Privacidad</a>
        <a href="#" class="hover:text-white transition-colors">Términos</a>
        <a href="#" class="hover:text-white transition-colors">Cookies</a>
      </div>
    </div>
  </div>

  <div class="absolute bottom-0 -left-1/4 w-[600px] h-[600px] bg-blue-950/10 rounded-full blur-[150px] pointer-events-none -z-10"></div>
</footer>