---
const contactInfo = [
  {
    icon: 'mail',
    label: 'Email',
    value: 'giancarlo@cosmicvirtualprojects.com',
    detail: 'Respuesta en menos de 24h',
  },
  {
    icon: 'phone',
    label: 'Teléfono',
    value: '+51 970 936 434',
    detail: 'Lun - Sab, 9:00 - 19:00',
  },
  {
    icon: 'map-pin',
    label: 'Ubicación',
    value: 'Lima, Perú',
    detail: 'San Isidro, Distrito Financiero',
  }
];
---

<section id='contactanos' class="py-32 relative overflow-hidden">
  
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-purple-900/10 rounded-full blur-[160px] pointer-events-none -z-10"></div>

  <div class="container mx-auto px-6 max-w-6xl relative z-10">
    
    <div class="mb-20">
      <h2 class="text-4xl md:text-5xl font-bold mb-4 text-white uppercase tracking-tight">Comencemos tu <br/> <span class="font-light italic tracking-tighter text-white uppercase tracking-tight">Transformación Digital</span></h2>
      <p class="text-gray-500 text-lg max-w-xl italic font-light">
        Agenda una consulta gratuita y descubre cómo podemos impulsar tu negocio con realidad virtual
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-stretch">
      
      <div class="lg:col-span-2 bg-[#121212]/40 backdrop-blur-xl border border-white/5 p-8 md:p-10 rounded-2xl shadow-2xl">
        <form  id="contactForm" class="grid grid-cols-1 md:grid-cols-2 gap-6">
          
          <div class="flex flex-col gap-2">
            <label class="text-[10px] font-bold text-gray-500 uppercase tracking-[0.2em] ml-1">Nombre</label>
            <input name="Persona" type="text" placeholder="Tu nombre" class="bg-black/40 border border-white/10 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-cyan-500/50 transition-all text-sm" />
          </div>

          <div class="flex flex-col gap-2">
            <label class="text-[10px] font-bold text-gray-500 uppercase tracking-[0.2em] ml-1">Email</label>
            <input name="email" type="email" placeholder="correo@empresa.com" class="bg-black/40 border border-white/10 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-purple-500/50 transition-all text-sm" />
          </div>

          <div class="flex flex-col gap-2">
            <label class="text-[10px] font-bold text-gray-500 uppercase tracking-[0.2em] ml-1">Teléfono</label>
            <input name="telefono" type="tel" placeholder="+51 000 000 000" class="bg-black/40 border border-white/10 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-cyan-500/50 transition-all text-sm" />
          </div>

          <div class="flex flex-col gap-2">
            <label class="text-[10px] font-bold text-gray-500 uppercase tracking-[0.2em] ml-1">Empresa</label>
            <input name="empresa" type="text" placeholder="Nombre de tu empresa" class="bg-black/40 border border-white/10 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-purple-500/50 transition-all text-sm" />
          </div>

          <div class="flex flex-col gap-2 md:col-span-2">
            <label class="text-[10px] font-bold text-gray-500 uppercase tracking-[0.2em] ml-1">Cuéntanos sobre tu proyecto</label>
            <textarea name="message" rows="4" placeholder="Descríbenos tu proyecto y objetivos, y te mostraremos cómo podemos ayudarte a lograr mejores resultados..." class="bg-black/40 border border-white/10 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-white/20 transition-all resize-none text-sm"></textarea>
          </div>

          <div class="md:col-span-2 mt-4">
            <button type="submit" class="w-full py-4 bg-white text-black font-bold rounded-lg hover:bg-gray-200 transition-all uppercase tracking-widest text-[11px] flex items-center justify-center gap-2 group">
              Enviar Mensaje
              <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
            </button>
          </div>

        </form>
        <p id="status"></p>
      </div>

      <div class="flex flex-col gap-4">
        {contactInfo.map((item) => (
          <div class="flex-grow bg-[#121212]/40 backdrop-blur-md border border-white/5 p-6 rounded-2xl flex items-center gap-5 transition-all hover:border-white/10 hover:bg-[#161616]/60 group cursor-default">
            <div class="w-12 h-12 rounded-full bg-black/50 border border-white/5 flex items-center justify-center flex-shrink-0 group-hover:border-cyan-500/30 transition-colors">
            
              {item.icon === 'mail' && <svg class="w-5 h-5 text-gray-400 group-hover:text-cyan-400 transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>}
              {item.icon === 'phone' && <svg class="w-5 h-5 text-gray-400 group-hover:text-cyan-400 transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>}
              {item.icon === 'map-pin' && <svg class="w-5 h-5 text-gray-400 group-hover:text-cyan-400 transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 1 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>}
            </div>
            <div class="flex flex-col">
              <span class="text-[10px] font-bold text-gray-600 uppercase tracking-widest mb-0.5">{item.label}</span>
              <span class="text-white text-sm font-medium">{item.value}</span>
              <span class="text-gray-600 text-[11px] font-light italic">{item.detail}</span>
            </div>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>

<script is:inline>
  const form = document.getElementById("contactForm");
  const status = document.getElementById("status");

  form.addEventListener("submit", async (e) => {
    e.preventDefault();

    const data = new FormData(form);

    try {
      const res = await fetch("https://formspree.io/f/mjgjrkzj", {
        method: "POST",
        body: data,
        headers: {
          "Accept": "application/json"
        }
      });

      if (res.ok) {
        status.textContent = "Mensaje enviado correctamente";
        form.reset();
      } else {
        status.textContent = "Error al enviar";
      }
    } catch (error) {
      status.textContent = "Error de conexión ";
    }
  });
</script>